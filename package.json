{
  "name": "brow-use",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:extension",
    "build:extension": "vite build --config extension.vite.config.ts && tsc -p extension/tsconfig.json && npm run copy:extension",
    "copy:extension": "cp extension/manifest.json extension/popup.html extension/sidepanel.html dist/extension/ && cp -r extension/icons dist/extension/",
    "dev:extension": "tsx scripts/watch-extension.ts",
    "chrome": "open -a 'Google Chrome' --args --remote-debugging-port=9222",
    "test": "node --import tsx --test tool/*.test.ts mcp/*.test.ts",
    "viewer:ingest": "tsx viewer/ingest.ts",
    "viewer:dev": "vite --config viewer.vite.config.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@tanstack/react-table": "^8.21.3",
    "diff": "^7.0.0",
    "diff2html": "^3.4.56",
    "playwright": "^1.50.0",
    "playwright-crx": "^0.15.0",
    "pngjs": "^7.0.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "vis-data": "^7.1.10",
    "vis-timeline": "^7.7.4",
    "ws": "^8.18.0",
    "yauzl": "^3.3.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.39",
    "@types/diff": "^7.0.2",
    "@types/node": "^22.0.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.0",
    "@types/yauzl": "^2.10.3",
    "@vitejs/plugin-react": "^5.2.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.3"
  }
}
